---
import { site } from '../data/content';
---
<header class="site-header" aria-label="En-tête principal">
  <div class="sh-inner">
    <a class="sh-brand" href="/#hero" aria-label="Retour à l'accueil">
      Sourcier <em>Québec</em>
    </a>

    <nav class="sh-nav" aria-label="Navigation principale">
      <a href="/#piliers">Démarche</a>
      <a href="/#forfaits">Forfaits</a>
      <a href="/#faq">FAQ</a>
      <a href="/#contact">Contact</a>
    </nav>

    <div class="sh-actions">
      <a class="sh-cta" href="/#contact">Demander une estimation</a>
      <a
        class="sh-fb"
        href={site.meta.facebookUrl}
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Page Facebook Sourcier Québec"
        title="Facebook"
      >
        <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" focusable="false">
          <path fill="currentColor" d="M13.5 22v-8.2h2.76l.41-3.2h-3.17V8.56c0-.93.26-1.56 1.59-1.56h1.7V4.13c-.3-.04-1.3-.13-2.47-.13-2.45 0-4.12 1.5-4.12 4.24v2.36H7.42v3.2h2.78V22h3.3z"/>
        </svg>
      </a>
    </div>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: rgba(var(--card-rgb), 0.88);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border-bottom: 1px solid rgba(var(--fg-rgb), 0.1);
    transition: background 350ms ease, border-color 350ms ease;
  }
  .sh-inner {
    max-width: 1400px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    padding: 0.85rem clamp(1.25rem, 4vw, 2.5rem);
  }
  .sh-brand {
    font-family: 'Playfair Display', serif;
    font-size: 1.25rem;
    font-weight: 500;
    color: var(--fg);
    text-decoration: none;
    letter-spacing: -0.01em;
    white-space: nowrap;
  }
  .sh-brand em {
    font-style: italic;
    color: var(--accent);
  }
  .sh-nav {
    display: flex;
    gap: 1.75rem;
  }
  .sh-nav a {
    color: rgba(var(--fg-rgb), 0.72);
    text-decoration: none;
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    transition: color 180ms ease;
  }
  .sh-nav a:hover { color: var(--accent); }

  .sh-actions {
    display: flex;
    align-items: center;
    gap: 0.85rem;
  }
  .sh-cta {
    display: inline-block;
    padding: 0.6rem 1.1rem;
    background: var(--accent);
    color: var(--bg);
    text-decoration: none;
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    transition: background 180ms ease, transform 180ms ease;
  }
  .sh-cta:hover {
    background: var(--accent-hover);
    transform: translateY(-1px);
  }
  .sh-fb {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 34px;
    height: 34px;
    border: 1px solid rgba(var(--fg-rgb), 0.25);
    color: rgba(var(--fg-rgb), 0.75);
    text-decoration: none;
    transition: color 180ms ease, border-color 180ms ease;
  }
  .sh-fb:hover {
    color: var(--accent);
    border-color: var(--accent);
  }

  @media (max-width: 860px) {
    .sh-nav { display: none; }
  }
  @media (max-width: 540px) {
    .sh-cta { display: none; }
    .sh-inner { gap: 0.75rem; }
  }
</style>
