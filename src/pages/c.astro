---
import Base from '../layouts/Base.astro';
import Switcher from '../components/Switcher.astro';
import { site } from '../data/content';
---
<Base title={`${site.meta.brand} — Direction C · Pur`}>
  <Fragment slot="head">
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,500;0,9..144,600;1,9..144,500;1,9..144,600&family=Inter:wght@300;400;500;600&display=swap"
    />
  </Fragment>

  <Switcher current="c" />

  <div class="page">
    <header class="masthead">
      <span>Sourcier Québec</span>
      <span>La Pocatière, QC</span>
    </header>

    <section class="hero" id="hero">
      <h1>
        L'<em>expertise</em> de l'eau<br />
        au service de <em>votre terrain.</em>
      </h1>
      <p class="lede">{site.hero.accroche}</p>
      <div class="actions">
        <a class="btn" href={site.hero.cta.href}>{site.hero.cta.label}</a>
        <a class="link" href="#forfaits">Voir les forfaits →</a>
      </div>
    </section>

    <hr />

    <section class="piliers" id="piliers">
      <h2>Trois piliers<br />de la <em>démarche</em>.</h2>
      <div class="grid3">
        {site.piliers.map((p) => (
          <article>
            <span class="num">{p.num}</span>
            <h3>{p.titre}</h3>
            <p>{p.texte}</p>
          </article>
        ))}
      </div>
    </section>

    <hr />

    <section class="about" id="about">
      <h2>À <em>propos</em>.</h2>
      <div class="about-grid">
        <div class="lead">
          <p>{site.about.intro}</p>
        </div>
        <div class="body">
          <p>{site.about.parcours}</p>
          <p>{site.about.methode}</p>
        </div>
      </div>
      <div class="points">
        {site.about.points.map((pt) => (
          <div>
            <p class="pt-title">{pt.titre}</p>
            <p class="pt-text">{pt.texte}</p>
          </div>
        ))}
      </div>
    </section>

    <hr />

    <section class="forfaits" id="forfaits">
      <h2><em>Forfaits.</em></h2>
      <ol class="forfaits-list">
        {site.forfaits.map((f) => (
          <li>
            <div class="forfait-main">
              <h3>{f.nom}</h3>
              <p class="f-surface">{f.surface} · {f.cible}</p>
              <ul>
                {f.inclusions.map((inc) => <li>{inc}</li>)}
              </ul>
            </div>
            <div class="forfait-price">
              <span class="price-n">{f.prix}</span>
              <span class="price-u">$</span>
            </div>
          </li>
        ))}
      </ol>
      <p class="note">{site.zone.note}</p>
    </section>

    <hr />

    <section class="zone" id="zone">
      <h2>Zone d'<em>intervention</em>.</h2>
      <div class="grid3 zone-grid">
        <div>
          <p class="key">Base</p>
          <p class="val">{site.zone.base}</p>
          <p class="val muted">{site.zone.coords}</p>
        </div>
        <div>
          <p class="key">Régions</p>
          {site.zone.regions.map((r) => <p class="val">{r}</p>)}
          <p class="val muted">{site.zone.autre}</p>
        </div>
        <div>
          <p class="key">Déplacement</p>
          <p class="val"><b>Inclus :</b> {site.zone.rayonInclus}</p>
          <p class="val"><b>Au-delà :</b> {site.zone.tarifKm}</p>
        </div>
      </div>
    </section>

    <hr />

    <section class="faq" id="faq">
      <h2>Questions <em>fréquentes</em>.</h2>
      <div class="faq-list">
        {site.faq.map((item, i) => (
          <details open={i === 0}>
            <summary>
              <span>{item.q}</span>
              <span class="toggle">+</span>
            </summary>
            <p>{item.r}</p>
          </details>
        ))}
      </div>
    </section>

    <hr />

    <section class="temoignages" id="temoignages">
      <h2><em>Témoignages.</em></h2>
      <p class="intro">{site.temoignages.intro}</p>
      <div class="t-list">
        {site.temoignages.placeholders.map((t) => (
          <figure>
            <blockquote>{t.texte}</blockquote>
            <figcaption>— {t.auteur}</figcaption>
          </figure>
        ))}
      </div>
    </section>

    <hr />

    <section class="contact" id="contact">
      <h2><em>Contact.</em></h2>
      <div class="contact-grid">
        <form class="form" method="post" action="#">
          <label><span>Nom</span><input type="text" name="nom" required /></label>
          <label><span>Courriel</span><input type="email" name="email" required /></label>
          <label><span>Téléphone</span><input type="tel" name="tel" /></label>
          <label><span>Type de projet</span>
            <select name="type">
              <option>Résidentiel</option>
              <option>Agricole / Grand terrain</option>
              <option>Municipal</option>
              <option>Autre</option>
            </select>
          </label>
          <label class="full"><span>Message</span><textarea name="message" rows="5" required></textarea></label>
          <button type="submit">Envoyer la demande →</button>
        </form>
        <aside class="coords">
          <div class="group">
            <p class="key">Adresse</p>
            <p class="val">{site.contact.adresse}</p>
          </div>
          <div class="group">
            <p class="key">Téléphone</p>
            <p class="val"><a href={`tel:${site.contact.telRaw}`}>{site.contact.tel}</a></p>
          </div>
          <div class="group">
            <p class="key">Courriel</p>
            <p class="val"><a href={`mailto:${site.contact.email}`}>{site.contact.email}</a></p>
          </div>
          <div class="group">
            <p class="key">Heures</p>
            <p class="val muted">{site.contact.horaires}</p>
          </div>
        </aside>
      </div>
    </section>

    <footer class="footer">
      <div class="foot-main">
        <div>
          <p class="f-brand">Sourcier Québec</p>
          <p class="f-muted">Thomas · Sourcier professionnel</p>
        </div>
        <div class="f-col">
          <p class="f-key">Contact</p>
          <p>{site.contact.tel}</p>
          <p>{site.contact.email}</p>
        </div>
        <div class="f-col">
          <p class="f-key">Aller à</p>
          <p><a href="#piliers">Démarche</a></p>
          <p><a href="#forfaits">Forfaits</a></p>
          <p><a href="#faq">FAQ</a></p>
          <p><a href="#contact">Contact</a></p>
        </div>
      </div>
      <div class="clause-wrap">
        <p class="f-key">Avis important</p>
        <p class="clause">{site.legal.clause}</p>
      </div>
      <div class="copy">
        <span>© 2026 Sourcier Québec</span>
        <span>La Pocatière, Québec</span>
      </div>
    </footer>
  </div>

  <style>
    :global(html, body) {
      margin: 0;
      padding: 0;
      background: #ffffff;
      color: #0a0a0a;
      font-family: 'Inter', system-ui, -apple-system, sans-serif;
      font-feature-settings: 'ss01', 'cv11';
      -webkit-font-smoothing: antialiased;
    }
    .page {
      max-width: 1040px;
      margin: 0 auto;
      padding: 0 clamp(1.25rem, 4vw, 2.5rem);
    }
    .masthead {
      display: flex;
      justify-content: space-between;
      padding: 1.5rem 0;
      font-size: 0.82rem;
      font-weight: 500;
      letter-spacing: -0.005em;
      border-bottom: 1px solid #e5e5e5;
    }
    section { padding: clamp(4.5rem, 9vh, 7rem) 0; }
    hr {
      border: none;
      border-top: 1px solid #e5e5e5;
      margin: 0;
    }

    /* Titres — Fraunces colorée, optical sizing activée */
    h1, h2, h3 {
      font-family: 'Fraunces', 'Crimson Pro', Georgia, serif;
      font-optical-sizing: auto;
      font-variation-settings: 'SOFT' 50, 'WONK' 0;
      color: #1e40af;
    }
    h1 {
      font-size: clamp(3rem, 7.5vw, 5.4rem);
      font-weight: 500;
      letter-spacing: -0.03em;
      line-height: 0.98;
      margin: 0 0 2rem;
      max-width: 15ch;
    }
    h1 em {
      font-style: italic;
      font-variation-settings: 'SOFT' 100, 'WONK' 1;
    }
    h2 {
      font-size: clamp(2.1rem, 4.2vw, 3.2rem);
      font-weight: 500;
      letter-spacing: -0.025em;
      line-height: 1.02;
      margin: 0 0 3rem;
      max-width: 16ch;
    }
    h2 em {
      font-style: italic;
      font-variation-settings: 'SOFT' 100, 'WONK' 1;
    }
    h3 {
      font-size: 1.4rem;
      font-weight: 500;
      letter-spacing: -0.01em;
      margin: 0;
    }

    /* Hero */
    .hero { padding-top: clamp(5rem, 10vh, 8rem); }
    .lede {
      font-size: clamp(1.1rem, 1.55vw, 1.25rem);
      line-height: 1.55;
      color: #4b4b4b;
      max-width: 56ch;
      margin: 0 0 2.5rem;
      font-weight: 400;
    }
    .actions {
      display: flex;
      align-items: center;
      gap: 1.5rem;
      flex-wrap: wrap;
    }
    .btn {
      display: inline-block;
      background: #0a0a0a;
      color: #ffffff;
      padding: 1rem 1.75rem;
      text-decoration: none;
      font-size: 0.88rem;
      font-weight: 500;
      letter-spacing: -0.005em;
      transition: background 180ms;
    }
    .btn:hover { background: #1e40af; }
    .link {
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      font-size: 0.88rem;
      font-weight: 500;
      color: #0a0a0a;
      text-decoration: none;
      border-bottom: 1px solid #0a0a0a;
      padding-bottom: 2px;
    }
    .link:hover { color: #1e40af; border-color: #1e40af; }

    /* Grid 3 colonnes */
    .grid3 {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 2.5rem;
    }

    /* Piliers */
    .piliers article .num {
      display: block;
      font-family: 'Fraunces', serif;
      font-size: 0.88rem;
      font-weight: 500;
      font-style: italic;
      color: #1e40af;
      margin-bottom: 1rem;
      letter-spacing: 0;
    }
    .piliers article h3 { margin: 0 0 0.75rem; font-size: 1.4rem; }
    .piliers article p {
      margin: 0;
      font-size: 0.98rem;
      line-height: 1.6;
      color: #4b4b4b;
      font-family: 'Inter', sans-serif;
    }

    /* About */
    .about-grid {
      display: grid;
      grid-template-columns: 1fr 1.4fr;
      gap: 3rem;
    }
    .about-grid .lead p {
      font-family: 'Fraunces', serif;
      font-size: 1.4rem;
      line-height: 1.4;
      font-weight: 500;
      font-style: italic;
      margin: 0;
      letter-spacing: -0.015em;
      color: #0a0a0a;
    }
    .about-grid .body p {
      margin: 0 0 1.1rem;
      line-height: 1.65;
      color: #4b4b4b;
      max-width: 60ch;
      font-size: 1rem;
    }
    .about-grid .body p:last-child { margin-bottom: 0; }
    .points {
      margin-top: 3rem;
      padding-top: 2.5rem;
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 2rem;
      border-top: 1px solid #e5e5e5;
    }
    .pt-title {
      font-family: 'Fraunces', serif;
      font-size: 1.05rem;
      font-weight: 600;
      font-style: italic;
      margin: 0 0 0.5rem;
      color: #1e40af;
    }
    .pt-text {
      margin: 0;
      font-size: 0.92rem;
      line-height: 1.55;
      color: #4b4b4b;
    }

    /* Forfaits */
    .forfaits-list { list-style: none; margin: 0; padding: 0; }
    .forfaits-list > li {
      display: grid;
      grid-template-columns: 1fr auto;
      gap: 2rem;
      padding: 2.25rem 0;
      border-top: 1px solid #e5e5e5;
      align-items: start;
    }
    .forfaits-list > li:last-child { border-bottom: 1px solid #e5e5e5; }
    .forfait-main h3 {
      font-size: 1.5rem;
      margin: 0 0 0.35rem;
    }
    .f-surface {
      font-size: 0.85rem;
      color: #6b6b6b;
      margin: 0 0 1rem;
    }
    .forfait-main ul {
      list-style: none;
      padding: 0;
      margin: 0;
      display: flex;
      gap: 0.4rem 1.75rem;
      flex-wrap: wrap;
    }
    .forfait-main ul li {
      font-size: 0.88rem;
      color: #4b4b4b;
      position: relative;
      padding-left: 0.9rem;
    }
    .forfait-main ul li::before {
      content: '—';
      position: absolute;
      left: 0;
      color: #9b9b9b;
    }
    .forfait-price {
      font-family: 'Fraunces', serif;
      display: flex;
      align-items: baseline;
      font-weight: 500;
      letter-spacing: -0.04em;
      color: #1e40af;
      line-height: 0.9;
    }
    .price-n {
      font-size: clamp(3.2rem, 5.5vw, 4.4rem);
      font-variation-settings: 'SOFT' 30;
    }
    .price-u {
      font-size: 1rem;
      margin-left: 0.3rem;
      color: #6b6b6b;
      letter-spacing: 0;
      font-weight: 500;
      align-self: flex-start;
      padding-top: 0.5rem;
      font-family: 'Inter', sans-serif;
    }
    .note {
      margin-top: 1.5rem;
      font-size: 0.82rem;
      color: #6b6b6b;
    }

    /* Zone */
    .zone-grid .key,
    .contact .key,
    .coords .group .key {
      font-family: 'Fraunces', serif;
      font-size: 0.92rem;
      font-weight: 500;
      font-style: italic;
      color: #1e40af;
      margin: 0 0 0.6rem;
    }
    .zone-grid .val {
      margin: 0 0 0.35rem;
      font-size: 0.98rem;
      line-height: 1.55;
      color: #0a0a0a;
    }
    .zone-grid .val b { color: #0a0a0a; font-weight: 500; }
    .zone-grid .val.muted {
      color: #9b9b9b;
      font-size: 0.85rem;
      margin-top: 0.5rem;
    }

    /* FAQ */
    .faq-list details {
      padding: 1.6rem 0;
      border-top: 1px solid #e5e5e5;
    }
    .faq-list details:last-child { border-bottom: 1px solid #e5e5e5; }
    .faq-list summary {
      display: flex;
      justify-content: space-between;
      align-items: center;
      cursor: pointer;
      font-family: 'Fraunces', serif;
      font-size: 1.2rem;
      font-weight: 500;
      list-style: none;
      gap: 1rem;
      color: #0a0a0a;
    }
    .faq-list summary::-webkit-details-marker { display: none; }
    .toggle {
      font-family: 'Inter', sans-serif;
      font-size: 1.4rem;
      color: #1e40af;
      font-weight: 300;
      line-height: 0.8;
      flex-shrink: 0;
    }
    .faq-list details[open] .toggle::before { content: '−'; }
    .faq-list details p {
      margin: 1rem 0 0;
      line-height: 1.65;
      color: #4b4b4b;
      max-width: 72ch;
      font-size: 0.98rem;
      font-family: 'Inter', sans-serif;
    }

    /* Témoignages */
    .intro {
      max-width: 60ch;
      margin: 0 0 2.5rem;
      color: #4b4b4b;
      line-height: 1.6;
    }
    .t-list figure {
      margin: 0;
      padding: 2.25rem 0;
      border-top: 1px solid #e5e5e5;
      display: grid;
      grid-template-columns: 1fr auto;
      gap: 2rem;
      align-items: start;
    }
    .t-list figure:last-child { border-bottom: 1px solid #e5e5e5; }
    .t-list blockquote {
      font-family: 'Fraunces', serif;
      margin: 0;
      font-size: 1.35rem;
      line-height: 1.45;
      max-width: 55ch;
      font-weight: 400;
      font-style: italic;
      letter-spacing: -0.01em;
      color: #0a0a0a;
    }
    .t-list figcaption {
      font-size: 0.82rem;
      color: #6b6b6b;
      font-weight: 500;
      align-self: center;
      white-space: nowrap;
    }

    /* Contact */
    .contact-grid {
      display: grid;
      grid-template-columns: 1.6fr 1fr;
      gap: 4rem;
    }
    .form {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1.5rem 1.25rem;
    }
    .form label {
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
    }
    .form label.full { grid-column: 1 / -1; }
    .form label > span {
      font-family: 'Fraunces', serif;
      font-style: italic;
      font-size: 0.92rem;
      font-weight: 500;
      color: #1e40af;
    }
    .form input, .form select, .form textarea {
      font-family: 'Inter', sans-serif;
      font-size: 1rem;
      padding: 0.75rem 0;
      background: transparent;
      border: none;
      border-bottom: 1px solid #0a0a0a;
      color: #0a0a0a;
      transition: border-color 180ms;
    }
    .form textarea { resize: vertical; }
    .form input:focus, .form select:focus, .form textarea:focus {
      outline: none;
      border-bottom-color: #1e40af;
      border-bottom-width: 2px;
    }
    .form button {
      grid-column: 1 / -1;
      justify-self: start;
      font-family: 'Inter', sans-serif;
      font-size: 0.88rem;
      font-weight: 500;
      padding: 1rem 1.75rem;
      background: #0a0a0a;
      color: #ffffff;
      border: none;
      cursor: pointer;
      margin-top: 0.75rem;
      transition: background 180ms;
    }
    .form button:hover { background: #1e40af; }
    .coords {
      display: flex;
      flex-direction: column;
      gap: 1.5rem;
    }
    .coords .group .val {
      margin: 0;
      font-size: 1rem;
      line-height: 1.5;
      color: #0a0a0a;
    }
    .coords .val.muted { color: #6b6b6b; font-size: 0.9rem; }
    .coords a {
      color: #0a0a0a;
      text-decoration: none;
      border-bottom: 1px solid #0a0a0a;
    }
    .coords a:hover { color: #1e40af; border-color: #1e40af; }

    /* Footer */
    .footer {
      margin-top: 4rem;
      padding: 4rem 0 2.5rem;
      border-top: 1px solid #e5e5e5;
    }
    .foot-main {
      display: grid;
      grid-template-columns: 2fr 1fr 1fr;
      gap: 2rem;
      margin-bottom: 3rem;
    }
    .f-brand {
      font-family: 'Fraunces', serif;
      font-size: 1.35rem;
      font-weight: 500;
      font-style: italic;
      margin: 0 0 0.25rem;
      color: #1e40af;
      letter-spacing: -0.01em;
    }
    .f-muted { font-size: 0.88rem; color: #6b6b6b; margin: 0; }
    .f-col .f-key {
      font-family: 'Fraunces', serif;
      font-style: italic;
      font-size: 0.92rem;
      font-weight: 500;
      margin: 0 0 0.75rem;
      color: #1e40af;
    }
    .f-col p {
      margin: 0 0 0.4rem;
      font-size: 0.92rem;
      color: #0a0a0a;
      font-family: 'Inter', sans-serif;
    }
    .f-col a {
      color: #0a0a0a;
      text-decoration: none;
      border-bottom: 1px solid transparent;
    }
    .f-col a:hover { border-color: #1e40af; color: #1e40af; }
    .clause-wrap {
      padding: 2rem 0;
      border-top: 1px solid #e5e5e5;
      border-bottom: 1px solid #e5e5e5;
      margin-bottom: 1.5rem;
    }
    .clause-wrap .f-key {
      font-family: 'Fraunces', serif;
      font-style: italic;
      font-size: 0.92rem;
      font-weight: 500;
      margin: 0 0 0.75rem;
      color: #1e40af;
    }
    .clause-wrap .clause {
      margin: 0;
      font-size: 0.85rem;
      line-height: 1.65;
      color: #4b4b4b;
      max-width: 85ch;
    }
    .copy {
      display: flex;
      justify-content: space-between;
      font-size: 0.78rem;
      color: #9b9b9b;
      flex-wrap: wrap;
      gap: 1rem;
    }

    @media (max-width: 900px) {
      .grid3 { grid-template-columns: 1fr; gap: 1.75rem; }
      .about-grid { grid-template-columns: 1fr; }
      .points { grid-template-columns: 1fr; }
      .forfaits-list > li { grid-template-columns: 1fr; gap: 1rem; }
      .t-list figure { grid-template-columns: 1fr; }
      .t-list figcaption { text-align: left; white-space: normal; }
      .contact-grid { grid-template-columns: 1fr; gap: 2.5rem; }
      .form { grid-template-columns: 1fr; }
      .foot-main { grid-template-columns: 1fr; }
    }
  </style>
</Base>
