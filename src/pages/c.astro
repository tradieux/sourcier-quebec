---
import Base from '../layouts/Base.astro';
import Switcher from '../components/Switcher.astro';
import { site } from '../data/content';
---
<Base title={`${site.meta.brand} — Direction C · Pur`}>
  <Fragment slot="head">
    <script is:inline>
      (function () {
        try {
          var saved = localStorage.getItem('palette-c');
          document.documentElement.dataset.palette = saved || 'c1';
        } catch (e) {
          document.documentElement.dataset.palette = 'c1';
        }
      })();
    </script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,500;0,9..144,600;1,9..144,500;1,9..144,600&family=Inter:wght@300;400;500;600&display=swap"
    />
  </Fragment>

  <Switcher current="c" />

  <div class="page">
    <nav class="palette-selector" aria-label="Choisir une palette de couleurs">
      <span class="sel-k">Palette</span>
      <button type="button" data-pal="c1" aria-label="Palette Océan claire">
        <span class="pal-chips" aria-hidden="true">
          <span style="background:#ffffff;outline:1px solid #e5e5e5;outline-offset:-1px"></span>
          <span style="background:#0a0a0a"></span>
          <span style="background:#0891b2"></span>
          <span style="background:#ef4444"></span>
          <span style="background:#6b6b6b"></span>
        </span>
        <span class="pal-label">Océan claire</span>
      </button>
      <button type="button" data-pal="c4" aria-label="Palette Océan foncée">
        <span class="pal-chips" aria-hidden="true">
          <span style="background:#061018"></span>
          <span style="background:#e6f0f4"></span>
          <span style="background:#06b6d4"></span>
          <span style="background:#f87171"></span>
          <span style="background:#94a3b8"></span>
        </span>
        <span class="pal-label">Océan foncée</span>
      </button>
      <button type="button" data-pal="c3" aria-label="Palette Émeraude claire">
        <span class="pal-chips" aria-hidden="true">
          <span style="background:#ffffff;outline:1px solid #e5e5e5;outline-offset:-1px"></span>
          <span style="background:#0a0a0a"></span>
          <span style="background:#059669"></span>
          <span style="background:#fb7185"></span>
          <span style="background:#6b6b6b"></span>
        </span>
        <span class="pal-label">Émeraude claire</span>
      </button>
      <button type="button" data-pal="c5" aria-label="Palette Émeraude foncée">
        <span class="pal-chips" aria-hidden="true">
          <span style="background:#061810"></span>
          <span style="background:#e8f0ea"></span>
          <span style="background:#10b981"></span>
          <span style="background:#fca5a5"></span>
          <span style="background:#94a3a0"></span>
        </span>
        <span class="pal-label">Émeraude foncée</span>
      </button>
      <button type="button" data-pal="c2" aria-label="Palette Éditorial">
        <span class="pal-chips" aria-hidden="true">
          <span style="background:#0a1f22"></span>
          <span style="background:#e6d5b4"></span>
          <span style="background:#2a6a70"></span>
          <span style="background:#d9923d"></span>
          <span style="background:#6b8a8e"></span>
        </span>
        <span class="pal-label">Éditorial</span>
      </button>
    </nav>

    <header class="masthead">
      <span>Sourcier Québec</span>
      <span>La Pocatière, QC</span>
    </header>

    <section class="hero" id="hero">
      <h1>
        L'<em>expertise</em> de l'eau<br />
        au service de <em>votre terrain.</em>
      </h1>
      <p class="lede">{site.hero.accroche}</p>
      <div class="actions">
        <a class="btn" href={site.hero.cta.href}>{site.hero.cta.label}</a>
        <a class="link" href="#forfaits">Voir les forfaits →</a>
      </div>
    </section>

    <hr />

    <section class="piliers" id="piliers">
      <h2>Trois piliers<br />de la <em>démarche</em>.</h2>
      <div class="grid3">
        {site.piliers.map((p) => (
          <article>
            <span class="num">{p.num}</span>
            <h3>{p.titre}</h3>
            <p>{p.texte}</p>
          </article>
        ))}
      </div>
    </section>

    <hr />

    <section class="about" id="about">
      <h2>À <em>propos</em>.</h2>
      <div class="about-grid">
        <figure class="portrait-col">
          <img src="/images/thomas.jpg" alt="Portrait de Thomas, sourcier professionnel en atelier" width="900" height="1200" />
          <figcaption>
            <span class="cap-name">Thomas</span>
            <span class="cap-role">Sourcier professionnel</span>
          </figcaption>
        </figure>
        <div class="text-col">
          <p class="lead">{site.about.intro}</p>
          <p>{site.about.parcours}</p>
          <p>{site.about.methode}</p>
        </div>
      </div>
      <div class="points">
        {site.about.points.map((pt) => (
          <div>
            <p class="pt-title">{pt.titre}</p>
            <p class="pt-text">{pt.texte}</p>
          </div>
        ))}
      </div>
    </section>

    <hr />

    <section class="forfaits" id="forfaits">
      <h2><em>Forfaits.</em></h2>
      <ol class="forfaits-list">
        {site.forfaits.map((f) => (
          <li>
            <div class="forfait-main">
              <h3>{f.nom}</h3>
              <p class="f-surface">{f.surface} · {f.cible}</p>
              <ul>
                {f.inclusions.map((inc) => <li>{inc}</li>)}
              </ul>
            </div>
            <div class="forfait-price">
              <span class="price-n">{f.prix}</span>
              <span class="price-u">$</span>
            </div>
          </li>
        ))}
      </ol>
      <p class="note">{site.zone.note}</p>
    </section>

    <hr />

    <section class="zone" id="zone">
      <h2>Zone d'<em>intervention</em>.</h2>
      <div class="grid3 zone-grid">
        <div>
          <p class="key">Base</p>
          <p class="val">{site.zone.base}</p>
          <p class="val muted">{site.zone.coords}</p>
        </div>
        <div>
          <p class="key">Régions</p>
          {site.zone.regions.map((r) => <p class="val">{r}</p>)}
          <p class="val muted">{site.zone.autre}</p>
        </div>
        <div>
          <p class="key">Déplacement</p>
          <p class="val"><b>Inclus :</b> {site.zone.rayonInclus}</p>
          <p class="val"><b>Au-delà :</b> {site.zone.tarifKm}</p>
        </div>
      </div>
    </section>

    <hr />

    <section class="faq" id="faq">
      <h2>Questions <em>fréquentes</em>.</h2>
      <div class="faq-list">
        {site.faq.map((item, i) => (
          <details open={i === 0}>
            <summary>
              <span>{item.q}</span>
              <span class="toggle">+</span>
            </summary>
            <p>{item.r}</p>
          </details>
        ))}
      </div>
    </section>

    <hr />

    <section class="temoignages" id="temoignages">
      <h2><em>Témoignages.</em></h2>
      <p class="intro">{site.temoignages.intro}</p>
      <div class="t-list">
        {site.temoignages.placeholders.map((t) => (
          <figure>
            <blockquote>{t.texte}</blockquote>
            <figcaption>— {t.auteur}</figcaption>
          </figure>
        ))}
      </div>
    </section>

    <hr />

    <section class="contact" id="contact">
      <h2><em>Contact.</em></h2>
      <div class="contact-grid">
        <form class="form" method="post" action="#">
          <label><span>Nom</span><input type="text" name="nom" required /></label>
          <label><span>Courriel</span><input type="email" name="email" required /></label>
          <label><span>Téléphone</span><input type="tel" name="tel" /></label>
          <label><span>Type de projet</span>
            <select name="type">
              <option>Résidentiel</option>
              <option>Agricole / Grand terrain</option>
              <option>Municipal</option>
              <option>Autre</option>
            </select>
          </label>
          <label class="full"><span>Message</span><textarea name="message" rows="5" required></textarea></label>
          <button type="submit">Envoyer la demande →</button>
        </form>
        <aside class="coords">
          <div class="group">
            <p class="key">Adresse</p>
            <p class="val">{site.contact.adresse}</p>
          </div>
          <div class="group">
            <p class="key">Téléphone</p>
            <p class="val"><a href={`tel:${site.contact.telRaw}`}>{site.contact.tel}</a></p>
          </div>
          <div class="group">
            <p class="key">Courriel</p>
            <p class="val"><a href={`mailto:${site.contact.email}`}>{site.contact.email}</a></p>
          </div>
          <div class="group">
            <p class="key">Heures</p>
            <p class="val muted">{site.contact.horaires}</p>
          </div>
        </aside>
      </div>
    </section>

    <hr />

    <section class="palette-strip" id="palette">
      <h2>Palette <em>chromatique.</em></h2>

      <div class="palette-display" data-pal="c1">
        <p class="intro">
          <strong>Océan claire</strong> — cyan profond et corail vif sur blanc pur. Référence directe à l'eau et à l'énergie, lecture claire et vibrante.
        </p>
        <div class="swatches">
          <div class="swatch"><div class="chip" style="background:#ffffff;border:1px solid #e5e5e5"></div><span class="sw-name">Blanc</span><span class="sw-hex">#FFFFFF</span></div>
          <div class="swatch"><div class="chip" style="background:#0a0a0a"></div><span class="sw-name">Encre</span><span class="sw-hex">#0A0A0A</span></div>
          <div class="swatch"><div class="chip" style="background:#0891b2"></div><span class="sw-name">Cyan</span><span class="sw-hex">#0891B2</span></div>
          <div class="swatch"><div class="chip" style="background:#ef4444"></div><span class="sw-name">Corail</span><span class="sw-hex">#EF4444</span></div>
          <div class="swatch"><div class="chip" style="background:#6b6b6b"></div><span class="sw-name">Graphite</span><span class="sw-hex">#6B6B6B</span></div>
        </div>
      </div>

      <div class="palette-display" data-pal="c4">
        <p class="intro">
          <strong>Océan foncée</strong> — variante nuit du même ADN cyan/corail, sur fond abysse profond. Cyan éclatant, corail adouci, atmosphère immersive.
        </p>
        <div class="swatches">
          <div class="swatch"><div class="chip" style="background:#061018"></div><span class="sw-name">Abysse</span><span class="sw-hex">#061018</span></div>
          <div class="swatch"><div class="chip" style="background:#e6f0f4"></div><span class="sw-name">Écume</span><span class="sw-hex">#E6F0F4</span></div>
          <div class="swatch"><div class="chip" style="background:#06b6d4"></div><span class="sw-name">Cyan vif</span><span class="sw-hex">#06B6D4</span></div>
          <div class="swatch"><div class="chip" style="background:#f87171"></div><span class="sw-name">Corail</span><span class="sw-hex">#F87171</span></div>
          <div class="swatch"><div class="chip" style="background:#94a3b8"></div><span class="sw-name">Brume</span><span class="sw-hex">#94A3B8</span></div>
        </div>
      </div>

      <div class="palette-display" data-pal="c3">
        <p class="intro">
          <strong>Émeraude claire</strong> — émeraude franc et rose corail sur blanc pur. Duo frais et vivant, contraste végétal / charnel qui accompagne le blanc.
        </p>
        <div class="swatches">
          <div class="swatch"><div class="chip" style="background:#ffffff;border:1px solid #e5e5e5"></div><span class="sw-name">Blanc</span><span class="sw-hex">#FFFFFF</span></div>
          <div class="swatch"><div class="chip" style="background:#0a0a0a"></div><span class="sw-name">Encre</span><span class="sw-hex">#0A0A0A</span></div>
          <div class="swatch"><div class="chip" style="background:#059669"></div><span class="sw-name">Émeraude</span><span class="sw-hex">#059669</span></div>
          <div class="swatch"><div class="chip" style="background:#fb7185"></div><span class="sw-name">Rose</span><span class="sw-hex">#FB7185</span></div>
          <div class="swatch"><div class="chip" style="background:#6b6b6b"></div><span class="sw-name">Graphite</span><span class="sw-hex">#6B6B6B</span></div>
        </div>
      </div>

      <div class="palette-display" data-pal="c5">
        <p class="intro">
          <strong>Émeraude foncée</strong> — variante sous-bois nocturne du même ADN émeraude/rose, sur fond forêt profonde. Vert éclatant, rose pâle, chaleur tamisée.
        </p>
        <div class="swatches">
          <div class="swatch"><div class="chip" style="background:#061810"></div><span class="sw-name">Forêt</span><span class="sw-hex">#061810</span></div>
          <div class="swatch"><div class="chip" style="background:#e8f0ea"></div><span class="sw-name">Mousse</span><span class="sw-hex">#E8F0EA</span></div>
          <div class="swatch"><div class="chip" style="background:#10b981"></div><span class="sw-name">Émeraude vif</span><span class="sw-hex">#10B981</span></div>
          <div class="swatch"><div class="chip" style="background:#fca5a5"></div><span class="sw-name">Rose pâle</span><span class="sw-hex">#FCA5A5</span></div>
          <div class="swatch"><div class="chip" style="background:#94a3a0"></div><span class="sw-name">Sauge</span><span class="sw-hex">#94A3A0</span></div>
        </div>
      </div>

      <div class="palette-display" data-pal="c2">
        <p class="intro">
          <strong>Éditorial</strong> — palette issue de B (eau teal + bokeh ambré). Abysse profond, brume chaude, cuivre oxydé. Mode sombre cinématographique sur structure minimaliste.
        </p>
        <div class="swatches">
          <div class="swatch"><div class="chip" style="background:#0a1f22"></div><span class="sw-name">Abysse</span><span class="sw-hex">#0A1F22</span></div>
          <div class="swatch"><div class="chip" style="background:#e6d5b4"></div><span class="sw-name">Brume</span><span class="sw-hex">#E6D5B4</span></div>
          <div class="swatch"><div class="chip" style="background:#2a6a70"></div><span class="sw-name">Oxyde</span><span class="sw-hex">#2A6A70</span></div>
          <div class="swatch"><div class="chip" style="background:#d9923d"></div><span class="sw-name">Ambre</span><span class="sw-hex">#D9923D</span></div>
          <div class="swatch"><div class="chip" style="background:#6b8a8e"></div><span class="sw-name">Brouillard</span><span class="sw-hex">#6B8A8E</span></div>
        </div>
      </div>
    </section>

    <footer class="footer">
      <div class="foot-main">
        <div>
          <p class="f-brand">Sourcier Québec</p>
          <p class="f-muted">Thomas · Sourcier professionnel</p>
        </div>
        <div class="f-col">
          <p class="f-key">Contact</p>
          <p>{site.contact.tel}</p>
          <p>{site.contact.email}</p>
        </div>
        <div class="f-col">
          <p class="f-key">Aller à</p>
          <p><a href="#piliers">Démarche</a></p>
          <p><a href="#forfaits">Forfaits</a></p>
          <p><a href="#faq">FAQ</a></p>
          <p><a href="#contact">Contact</a></p>
        </div>
      </div>
      <div class="clause-wrap">
        <p class="f-key">Avis important</p>
        <p class="clause">{site.legal.clause}</p>
      </div>
      <div class="copy">
        <span>© 2026 Sourcier Québec</span>
        <span>La Pocatière, Québec</span>
      </div>
    </footer>
  </div>

  <script is:inline>
    (function () {
      var buttons = document.querySelectorAll('.palette-selector button');
      var root = document.documentElement;
      function setActive(pal) {
        root.dataset.palette = pal;
        try { localStorage.setItem('palette-c', pal); } catch (e) {}
        buttons.forEach(function (b) {
          b.classList.toggle('active', b.dataset.pal === pal);
        });
      }
      buttons.forEach(function (b) {
        b.addEventListener('click', function () { setActive(b.dataset.pal); });
      });
      setActive(root.dataset.palette || 'c1');
    })();
  </script>

  <style>
    :root[data-palette="c1"] {
      /* Océan claire — cyan + corail sur blanc */
      --bg: #ffffff;
      --fg: #0a0a0a;
      --fg-rgb: 10, 10, 10;
      --accent: #0891b2;
      --accent2: #ef4444;
      --muted: #6b6b6b;
      --border: #e5e5e5;
      --lead-bg: #fafafa;
    }
    :root[data-palette="c2"] {
      /* Éditorial — thème de B, dark teal + ambre */
      --bg: #0a1f22;
      --fg: #e6d5b4;
      --fg-rgb: 230, 213, 180;
      --accent: #d9923d;
      --accent2: #2a6a70;
      --muted: #6b8a8e;
      --border: rgba(230, 213, 180, 0.18);
      --lead-bg: #0e262b;
    }
    :root[data-palette="c3"] {
      /* Émeraude claire — émeraude + rose sur blanc */
      --bg: #ffffff;
      --fg: #0a0a0a;
      --fg-rgb: 10, 10, 10;
      --accent: #059669;
      --accent2: #fb7185;
      --muted: #6b6b6b;
      --border: #e5e5e5;
      --lead-bg: #fafafa;
    }
    :root[data-palette="c4"] {
      /* Océan foncée — variante nuit, fond abysse */
      --bg: #061018;
      --fg: #e6f0f4;
      --fg-rgb: 230, 240, 244;
      --accent: #06b6d4;
      --accent2: #f87171;
      --muted: #94a3b8;
      --border: rgba(230, 240, 244, 0.15);
      --lead-bg: #0a1821;
    }
    :root[data-palette="c5"] {
      /* Émeraude foncée — variante sous-bois, fond forêt */
      --bg: #061810;
      --fg: #e8f0ea;
      --fg-rgb: 232, 240, 234;
      --accent: #10b981;
      --accent2: #fca5a5;
      --muted: #94a3a0;
      --border: rgba(232, 240, 234, 0.15);
      --lead-bg: #0a1f15;
    }

    :global(html, body) {
      margin: 0;
      padding: 0;
      background: var(--bg);
      color: var(--fg);
      font-family: 'Inter', system-ui, -apple-system, sans-serif;
      font-feature-settings: 'ss01', 'cv11';
      -webkit-font-smoothing: antialiased;
      transition: background 350ms ease, color 350ms ease;
    }
    .page {
      max-width: 1040px;
      margin: 0 auto;
      padding: 0 clamp(1.25rem, 4vw, 2.5rem);
    }

    /* Palette selector — sticky, chips de couleur visibles */
    .palette-selector {
      position: sticky;
      top: 2.25rem;
      z-index: 90;
      display: flex;
      align-items: center;
      gap: 0.65rem;
      padding: 0.85rem 0;
      margin: 0 calc(clamp(1.25rem, 4vw, 2.5rem) * -1);
      padding-left: clamp(1.25rem, 4vw, 2.5rem);
      padding-right: clamp(1.25rem, 4vw, 2.5rem);
      background: var(--bg);
      border-bottom: 1px solid var(--border);
      flex-wrap: wrap;
    }
    .palette-selector .sel-k {
      font-family: 'Inter', sans-serif;
      font-size: 0.7rem;
      font-weight: 500;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: var(--muted);
      margin-right: 0.25rem;
    }
    .palette-selector button {
      display: inline-flex;
      align-items: center;
      gap: 0.55rem;
      padding: 0.4rem 0.75rem 0.4rem 0.5rem;
      background: transparent;
      border: 1px solid var(--border);
      cursor: pointer;
      transition: all 180ms;
      font-family: inherit;
    }
    .palette-selector button:hover {
      border-color: var(--fg);
      transform: translateY(-1px);
    }
    .palette-selector button.active {
      border-color: var(--fg);
      background: color-mix(in srgb, var(--fg) 4%, var(--bg));
    }
    .pal-chips {
      display: inline-flex;
      gap: 0;
    }
    .pal-chips span {
      display: block;
      width: 16px;
      height: 18px;
    }
    .pal-label {
      font-family: 'Fraunces', serif;
      font-style: italic;
      font-size: 1rem;
      color: var(--fg);
      font-weight: 500;
      line-height: 1;
    }
    @media (max-width: 640px) {
      .palette-selector { gap: 0.4rem; padding: 0.65rem clamp(1.25rem, 4vw, 2.5rem); }
      .palette-selector .sel-k { width: 100%; margin-bottom: 0.25rem; }
    }

    .masthead {
      display: flex;
      justify-content: space-between;
      padding: 1.5rem 0;
      font-size: 0.82rem;
      font-weight: 500;
      letter-spacing: -0.005em;
      border-top: 1px solid var(--border);
      border-bottom: 1px solid var(--border);
    }
    section { padding: clamp(4.5rem, 9vh, 7rem) 0; }
    hr {
      border: none;
      border-top: 1px solid var(--border);
      margin: 0;
    }

    /* Titres — Fraunces colorée */
    h1, h2, h3 {
      font-family: 'Fraunces', 'Crimson Pro', Georgia, serif;
      font-optical-sizing: auto;
      font-variation-settings: 'SOFT' 50, 'WONK' 0;
      color: var(--accent);
    }
    h1 {
      font-size: clamp(3rem, 7.5vw, 5.4rem);
      font-weight: 500;
      letter-spacing: -0.03em;
      line-height: 0.98;
      margin: 0 0 2rem;
      max-width: 15ch;
    }
    h1 em {
      font-style: italic;
      font-variation-settings: 'SOFT' 100, 'WONK' 1;
      color: var(--accent2);
    }
    h2 {
      font-size: clamp(2.1rem, 4.2vw, 3.2rem);
      font-weight: 500;
      letter-spacing: -0.025em;
      line-height: 1.02;
      margin: 0 0 3rem;
      max-width: 16ch;
    }
    h2 em {
      font-style: italic;
      font-variation-settings: 'SOFT' 100, 'WONK' 1;
      color: var(--accent2);
    }
    h3 {
      font-size: 1.4rem;
