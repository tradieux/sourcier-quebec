    .p-stats dd { margin: 0; font-size: 0.75rem; color: var(--fg); font-weight: 500; }

    .expert-bio p {
      font-size: 1.08rem;
      line-height: 1.6;
      margin: 0 0 1.25rem;
    }
    .expert-bio .drop::first-letter {
      font-size: 3.5em;
      float: left;
      line-height: 0.85;
      padding: 0.1em 0.1em 0 0;
