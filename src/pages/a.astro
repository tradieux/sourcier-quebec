    @media (max-width: 860px) {
      .expert-grid { grid-template-columns: 1fr; }
      .portrait-card { position: static; max-width: 360px; }
      .piliers-grid { grid-template-columns: 1fr; }
      .contact-grid, .foot-grid { grid-template-columns: 1fr; }
