    .row h3 { margin: 0 0 0.5rem; font-size: 1.35rem; font-weight: 500; }
    .cible { margin: 0 0 0.75rem; font-style: italic; color: rgba(var(--fg-rgb), 0.7); font-size: 0.95rem; }
    .row ul { margin: 0; padding-left: 1rem; font-size: 0.92rem; color: rgba(var(--fg-rgb), 0.8); }
