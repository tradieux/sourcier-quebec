    .coords a:hover { color: var(--accent); border-color: var(--accent); }

    /* Palette strip */
    .palette-display { display: none; }
    :root[data-palette="a1"] .palette-display[data-pal="a1"],
    :root[data-palette="a2"] .palette-display[data-pal="a2"],
    :root[data-palette="a3"] .palette-display[data-pal="a3"],
    :root[data-palette="a4"] .palette-display[data-pal="a4"],
