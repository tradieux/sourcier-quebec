    .credential {
      display: grid;
      grid-template-columns: auto 1fr;
      gap: 1.25rem;
      align-items: start;
    }
    .c-num {
      font-family: 'JetBrains Mono', monospace;
      font-size: 1.5rem;
      font-weight: 500;
