---
import Base from '../layouts/Base.astro';
import Switcher from '../components/Switcher.astro';
import { site } from '../data/content';
---
<Base title={`${site.meta.brand} — Direction A · Cartographique`}>
  <Fragment slot="head">
    <script is:inline>
      (function() {
        try {
          var saved = localStorage.getItem('palette-a');
          document.documentElement.dataset.palette = saved || 'a1';
        } catch (e) {
          document.documentElement.dataset.palette = 'a1';
        }
      })();
    </script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Crimson+Pro:ital,wght@0,400;0,500;0,600;1,400;1,500&family=Inter:wght@400;500&family=JetBrains+Mono:wght@400;500;600&display=swap"
    />
  </Fragment>

  <Switcher current="a" />

  <div class="page">
    <nav class="palette-selector" aria-label="Choisir une palette de couleurs">
      <span class="sel-k">Palette</span>
      <button type="button" data-pal="a1" aria-label="Palette Éditorial">
        <span class="pal-chips" aria-hidden="true">
          <span style="background:#0a1f22"></span>
          <span style="background:#e6d5b4"></span>
          <span style="background:#2a6a70"></span>
          <span style="background:#d9923d"></span>
          <span style="background:#6b8a8e"></span>
        </span>
        <span class="pal-label">Éditorial</span>
      </button>
      <button type="button" data-pal="a2" aria-label="Palette Marine claire">
        <span class="pal-chips" aria-hidden="true">
          <span style="background:#ede2c8"></span>
          <span style="background:#14284a"></span>
          <span style="background:#1a4a8c"></span>
          <span style="background:#c89548"></span>
          <span style="background:#6a5f42"></span>
        </span>
        <span class="pal-label">Marine claire</span>
      </button>
      <button type="button" data-pal="a3" aria-label="Palette Rouille claire">
        <span class="pal-chips" aria-hidden="true">
          <span style="background:#f0e5c8"></span>
          <span style="background:#1a1510"></span>
          <span style="background:#b04a28"></span>
          <span style="background:#a8855a"></span>
          <span style="background:#6a5242"></span>
        </span>
        <span class="pal-label">Rouille claire</span>
      </button>
      <button type="button" data-pal="a4" aria-label="Palette Marine foncée">
        <span class="pal-chips" aria-hidden="true">
          <span style="background:#0a1528"></span>
          <span style="background:#e8ecf2"></span>
          <span style="background:#3b82f6"></span>
          <span style="background:#fbbf24"></span>
          <span style="background:#8596a8"></span>
        </span>
        <span class="pal-label">Marine foncée</span>
      </button>
      <button type="button" data-pal="a5" aria-label="Palette Rouille foncée">
        <span class="pal-chips" aria-hidden="true">
          <span style="background:#1a120a"></span>
          <span style="background:#f0e5d0"></span>
          <span style="background:#ea580c"></span>
          <span style="background:#d4a574"></span>
          <span style="background:#8a7560"></span>
        </span>
        <span class="pal-label">Rouille foncée</span>
      </button>
    </nav>

    <div class="topbar">
      <span>Sourcier Québec</span>
      <span>47.3667° N · 70.0333° O · La Pocatière, QC</span>
    </div>

    <section class="hero" id="hero">
      <p class="byline">
        <span class="by-k">Par</span>
        <span class="by-name">Thomas</span>
        <span class="by-sep">·</span>
        <span class="by-role">Sourcier professionnel certifié · 10+ ans d'expérience</span>
      </p>
      <h1>
        L'expertise de l'eau<br />
        au service de <em>votre terrain.</em>
      </h1>
      <p class="lede">{site.hero.accroche}</p>
      <div class="hero-actions">
        <a class="btn" href={site.hero.cta.href}>{site.hero.cta.label}</a>
        <a class="btn-ghost" href="#expert">Rencontrer l'expert</a>
      </div>
    </section>

    <section class="expert" id="expert">
      <header class="section-head">
        <h2>L'expert derrière la démarche</h2>
      </header>
      <div class="expert-grid">
        <aside class="portrait-card">
          <div class="p-header">
            <span>Fiche expert · 01</span>
            <span>Sourcier Québec</span>
          </div>
          <div class="p-frame">
            <img src="/images/thomas.jpg" alt="Portrait de Thomas, sourcier professionnel en atelier" width="900" height="1200" />
          </div>
          <div class="p-footer">
            <p class="p-name">Thomas</p>
            <p class="p-role">Sourcier professionnel</p>
            <dl class="p-stats">
              <div><dt>Basé à</dt><dd>La Pocatière, QC</dd></div>
              <div><dt>Pratique</dt><dd>10+ années</dd></div>
              <div><dt>Formation</dt><dd>Certifiée France</dd></div>
            </dl>
          </div>
        </aside>
        <div class="expert-bio">
          <p class="drop">{site.about.intro}</p>
          <p>{site.about.parcours}</p>
          <p>{site.about.methode}</p>
          <div class="credentials">
            {site.about.points.map((pt, i) => (
              <div class="credential">
                <span class="c-num">0{i + 1}</span>
                <div>
                  <h4>{pt.titre}</h4>
                  <p>{pt.texte}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <section class="piliers" id="piliers">
      <header class="section-head">
        <h2>Les trois piliers de la démarche</h2>
      </header>
      <div class="piliers-grid">
        {site.piliers.map((p) => (
          <article class="pilier">
            <span class="p-num">{p.num}</span>
            <h3>{p.titre}</h3>
            <p>{p.texte}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="forfaits" id="forfaits">
      <header class="section-head">
        <h2>Forfaits et tarification</h2>
      </header>
      <div class="table">
        <div class="thead">
          <span>Forfait</span>
          <span>Périmètre</span>
          <span>Tarif</span>
        </div>
        {site.forfaits.map((f) => (
          <article class="row">
            <div class="cell name">
              <h3>{f.nom}</h3>
              <p class="cible">{f.cible}</p>
              <ul>
                {f.inclusions.map((inc) => <li>{inc}</li>)}
              </ul>
            </div>
            <div class="cell surface">
              <span class="k">Surface</span>
              <span class="v">{f.surface}</span>
            </div>
            <div class="cell prix">
              <span class="amount">{f.prix}<sup>$</sup></span>
            </div>
          </article>
        ))}
      </div>
      <p class="note">{site.zone.note}</p>
    </section>

    <section class="zone" id="zone">
      <header class="section-head">
        <h2>Zone d'intervention</h2>
      </header>
      <div class="zone-grid">
        <div>
          <p class="label">Base opérationnelle</p>
          <p class="big">{site.zone.base}</p>
          <p class="coord">{site.zone.coords}</p>
        </div>
        <div>
          <p class="label">Régions principales</p>
          <ul class="regions">
            {site.zone.regions.map((r) => <li>{r}</li>)}
          </ul>
          <p class="muted">{site.zone.autre}</p>
        </div>
        <div>
          <p class="label">Frais de déplacement</p>
          <p><strong>Inclus :</strong> {site.zone.rayonInclus}</p>
          <p><strong>Au-delà :</strong> {site.zone.tarifKm}</p>
        </div>
      </div>
    </section>

    <section class="faq" id="faq">
      <header class="section-head">
        <h2>Foire aux questions</h2>
      </header>
      <div class="faq-list">
        {site.faq.map((item, i) => (
          <details open={i === 0}>
            <summary>
              <span>{item.q}</span>
              <span class="chev">+</span>
            </summary>
            <p>{item.r}</p>
          </details>
        ))}
      </div>
    </section>

    <section class="temoignages" id="temoignages">
      <header class="section-head">
        <h2>Témoignages</h2>
      </header>
      <p class="intro-t">{site.temoignages.intro}</p>
      <div class="avis">
        {site.temoignages.placeholders.map((t) => (
          <blockquote>
            <p>« {t.texte} »</p>
            <footer>— {t.auteur}</footer>
          </blockquote>
        ))}
      </div>
    </section>

    <section class="contact" id="contact">
      <header class="section-head">
        <h2>Formulaire de contact</h2>
      </header>
      <div class="contact-grid">
        <form class="form" method="post" action="#" aria-label="Formulaire de contact">
          <label><span>Nom</span><input type="text" name="nom" required /></label>
          <label><span>Courriel</span><input type="email" name="email" required /></label>
          <label><span>Téléphone</span><input type="tel" name="tel" /></label>
          <label><span>Type de projet</span>
            <select name="type">
              <option>Résidentiel</option>
              <option>Agricole / Grand terrain</option>
              <option>Municipal</option>
              <option>Autre</option>
            </select>
          </label>
          <label class="full"><span>Décrivez votre projet</span><textarea name="message" rows="5" required></textarea></label>
          <button type="submit">Envoyer la demande →</button>
        </form>
        <aside class="coords">
          <p class="label">Coordonnées</p>
          <p>{site.contact.adresse}</p>
          <p><a href={`tel:${site.contact.telRaw}`}>{site.contact.tel}</a></p>
          <p><a href={`mailto:${site.contact.email}`}>{site.contact.email}</a></p>
          <p class="muted">{site.contact.horaires}</p>
        </aside>
      </div>
    </section>

    <section class="palette-strip" id="palette">
      <header class="section-head">
        <h2>Palette chromatique</h2>
      </header>

      <div class="palette-display" data-pal="a1">
        <p class="palette-intro">
          <strong>Éditorial</strong> — palette issue de B (eau teal + bokeh ambré). Abysse profond, brume chaude, oxyde de cuivre. Mode sombre cinématographique appliqué à la structure cartographique.
        </p>
        <div class="swatches">
          <div class="swatch"><div class="chip" style="background:#0a1f22"></div><span class="sw-name">Abysse</span><span class="sw-hex">#0A1F22</span></div>
          <div class="swatch"><div class="chip" style="background:#e6d5b4"></div><span class="sw-name">Brume</span><span class="sw-hex">#E6D5B4</span></div>
          <div class="swatch"><div class="chip" style="background:#2a6a70"></div><span class="sw-name">Oxyde</span><span class="sw-hex">#2A6A70</span></div>
          <div class="swatch"><div class="chip" style="background:#d9923d"></div><span class="sw-name">Ambre</span><span class="sw-hex">#D9923D</span></div>
          <div class="swatch"><div class="chip" style="background:#6b8a8e"></div><span class="sw-name">Brouillard</span><span class="sw-hex">#6B8A8E</span></div>
        </div>
      </div>

      <div class="palette-display" data-pal="a2">
        <p class="palette-intro">
          <strong>Marine claire</strong> — sable chaud, outremer profond, cobalt pétrole, or vieilli. Accent bleu franc qui porte l'autorité maritime, sur fond kraft.
        </p>
        <div class="swatches">
          <div class="swatch"><div class="chip" style="background:#ede2c8"></div><span class="sw-name">Sable</span><span class="sw-hex">#EDE2C8</span></div>
          <div class="swatch"><div class="chip" style="background:#14284a"></div><span class="sw-name">Outremer</span><span class="sw-hex">#14284A</span></div>
          <div class="swatch"><div class="chip" style="background:#1a4a8c"></div><span class="sw-name">Cobalt</span><span class="sw-hex">#1A4A8C</span></div>
          <div class="swatch"><div class="chip" style="background:#c89548"></div><span class="sw-name">Or</span><span class="sw-hex">#C89548</span></div>
          <div class="swatch"><div class="chip" style="background:#6a5f42"></div><span class="sw-name">Galet</span><span class="sw-hex">#6A5F42</span></div>
        </div>
      </div>

      <div class="palette-display" data-pal="a3">
        <p class="palette-intro">
          <strong>Rouille claire</strong> — crème chaude, charbon profond, rouille terre cuite, tan chamois. Accents qui évoquent le fer, la terre et le temps, sur fond crème.
        </p>
        <div class="swatches">
          <div class="swatch"><div class="chip" style="background:#f0e5c8"></div><span class="sw-name">Crème</span><span class="sw-hex">#F0E5C8</span></div>
          <div class="swatch"><div class="chip" style="background:#1a1510"></div><span class="sw-name">Charbon</span><span class="sw-hex">#1A1510</span></div>
          <div class="swatch"><div class="chip" style="background:#b04a28"></div><span class="sw-name">Rouille</span><span class="sw-hex">#B04A28</span></div>
          <div class="swatch"><div class="chip" style="background:#a8855a"></div><span class="sw-name">Tan</span><span class="sw-hex">#A8855A</span></div>
          <div class="swatch"><div class="chip" style="background:#6a5242"></div><span class="sw-name">Pierre</span><span class="sw-hex">#6A5242</span></div>
        </div>
      </div>

      <div class="palette-display" data-pal="a4">
        <p class="palette-intro">
          <strong>Marine foncée</strong> — variante nuit : abysse outremer comme fond, cream cool comme texte, cobalt vif et or doré éclatants. Le même ADN maritime renversé en mode sombre.
        </p>
        <div class="swatches">
          <div class="swatch"><div class="chip" style="background:#0a1528"></div><span class="sw-name">Abysse</span><span class="sw-hex">#0A1528</span></div>
          <div class="swatch"><div class="chip" style="background:#e8ecf2"></div><span class="sw-name">Écume</span><span class="sw-hex">#E8ECF2</span></div>
          <div class="swatch"><div class="chip" style="background:#3b82f6"></div><span class="sw-name">Cobalt vif</span><span class="sw-hex">#3B82F6</span></div>
          <div class="swatch"><div class="chip" style="background:#fbbf24"></div><span class="sw-name">Or</span><span class="sw-hex">#FBBF24</span></div>
          <div class="swatch"><div class="chip" style="background:#8596a8"></div><span class="sw-name">Brume</span><span class="sw-hex">#8596A8</span></div>
        </div>
      </div>

      <div class="palette-display" data-pal="a5">
        <p class="palette-intro">
          <strong>Rouille foncée</strong> — variante forge : charbon d'atelier comme fond, cream brûlé comme texte, rouille vive et tan doré éclatants. Le même ADN terreux en mode sombre.
        </p>
        <div class="swatches">
          <div class="swatch"><div class="chip" style="background:#1a120a"></div><span class="sw-name">Charbon</span><span class="sw-hex">#1A120A</span></div>
          <div class="swatch"><div class="chip" style="background:#f0e5d0"></div><span class="sw-name">Cendre</span><span class="sw-hex">#F0E5D0</span></div>
          <div class="swatch"><div class="chip" style="background:#ea580c"></div><span class="sw-name">Rouille vive</span><span class="sw-hex">#EA580C</span></div>
          <div class="swatch"><div class="chip" style="background:#d4a574"></div><span class="sw-name">Tan</span><span class="sw-hex">#D4A574</span></div>
          <div class="swatch"><div class="chip" style="background:#8a7560"></div><span class="sw-name">Pierre</span><span class="sw-hex">#8A7560</span></div>
        </div>
      </div>
    </section>

    <footer class="footer" id="footer">
      <div class="foot-grid">
        <div>
          <p class="brand">Sourcier Québec</p>
          <p class="muted">Thomas · Sourcier professionnel</p>
        </div>
        <div>
          <p class="label">Contact</p>
          <p>{site.contact.tel}</p>
          <p>{site.contact.email}</p>
        </div>
        <div>
          <p class="label">Avis important</p>
          <p class="clause">{site.legal.clause}</p>
        </div>
      </div>
      <div class="copy">
        <span>© 2026 Sourcier Québec</span>
        <span>Conçu avec précision · La Pocatière</span>
      </div>
    </footer>
  </div>

  <script is:inline>
    (function () {
      var buttons = document.querySelectorAll('.palette-selector button');
      var root = document.documentElement;
      function setActive(pal) {
        root.dataset.palette = pal;
        try { localStorage.setItem('palette-a', pal); } catch (e) {}
        buttons.forEach(function (b) {
          b.classList.toggle('active', b.dataset.pal === pal);
        });
      }
      buttons.forEach(function (b) {
        b.addEventListener('click', function () { setActive(b.dataset.pal); });
      });
      setActive(root.dataset.palette || 'a1');
    })();
  </script>

  <style>
    :root[data-palette="a1"] {
      /* Éditorial — thème de B, dark teal + ambre */
      --bg: #0a1f22;
      --fg: #e6d5b4;
      --fg-rgb: 230, 213, 180;
      --accent: #d9923d;
      --accent2: #2a6a70;
      --card: #0e262b;
      --card-rgb: 14, 38, 43;
    }
    :root[data-palette="a2"] {
      /* Marine claire — sable + cobalt + or */
      --bg: #ede2c8;
      --fg: #14284a;
      --fg-rgb: 20, 40, 74;
      --accent: #1a4a8c;
      --accent2: #c89548;
      --card: #f3e8ce;
      --card-rgb: 243, 232, 206;
    }
    :root[data-palette="a3"] {
      /* Rouille claire — crème + charbon + rouille */
      --bg: #f0e5c8;
      --fg: #1a1510;
      --fg-rgb: 26, 21, 16;
      --accent: #b04a28;
      --accent2: #a8855a;
      --card: #f5eace;
      --card-rgb: 245, 234, 206;
    }
    :root[data-palette="a4"] {
      /* Marine foncée — variante nuit, fond abysse */
      --bg: #0a1528;
      --fg: #e8ecf2;
      --fg-rgb: 232, 236, 242;
      --accent: #3b82f6;
      --accent2: #fbbf24;
      --card: #122040;
      --card-rgb: 18, 32, 64;
    }
    :root[data-palette="a5"] {
      /* Rouille foncée — variante forge, fond charbon */
      --bg: #1a120a;
      --fg: #f0e5d0;
      --fg-rgb: 240, 229, 208;
      --accent: #ea580c;
      --accent2: #d4a574;
      --card: #231710;
      --card-rgb: 35, 23, 16;
    }

    /* Overrides pour le portrait en mode sombre (Éditorial, Marine foncée, Rouille foncée) */
    :root[data-palette="a1"] .p-frame img,
    :root[data-palette="a4"] .p-frame img,
    :root[data-palette="a5"] .p-frame img {
      mix-blend-mode: normal;
      filter: grayscale(1) contrast(1.12) brightness(1.05);
    }

    :global(html, body) {
      margin: 0;
      padding: 0;
      background: var(--bg);
      color: var(--fg);
      font-family: 'Crimson Pro', ui-serif, Georgia, serif;
      -webkit-font-smoothing: antialiased;
      transition: background 350ms ease, color 350ms ease;
    }
    :global(body) {
      background-image: radial-gradient(circle at 1px 1px, rgba(var(--fg-rgb), 0.08) 1px, transparent 0);
      background-size: 24px 24px;
    }
    .page {
      max-width: 1040px;
      margin: 0 auto;
      padding: 0 clamp(1.25rem, 4vw, 2.5rem);
    }

    /* Palette selector — sticky, avec chips de couleur visibles */
    .palette-selector {
      position: sticky;
      top: 2.25rem;
      z-index: 90;
      display: flex;
      align-items: center;
      gap: 0.65rem;
      padding: 0.85rem 0;
      margin: 0 calc(clamp(1.25rem, 4vw, 2.5rem) * -1);
      padding-left: clamp(1.25rem, 4vw, 2.5rem);
      padding-right: clamp(1.25rem, 4vw, 2.5rem);
      background: var(--bg);
      border-bottom: 1px solid rgba(var(--fg-rgb), 0.18);
      flex-wrap: wrap;
    }
    .palette-selector .sel-k {
      font-family: 'JetBrains Mono', ui-monospace, monospace;
      font-size: 0.64rem;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: rgba(var(--fg-rgb), 0.5);
      margin-right: 0.25rem;
    }
    .palette-selector button {
      display: inline-flex;
      align-items: center;
      gap: 0.55rem;
      padding: 0.4rem 0.65rem 0.4rem 0.45rem;
      background: transparent;
      border: 1px solid rgba(var(--fg-rgb), 0.22);
      cursor: pointer;
      transition: all 180ms;
      font-family: inherit;
    }
    .palette-selector button:hover {
      border-color: var(--fg);
      transform: translateY(-1px);
    }
    .palette-selector button.active {
      border-color: var(--fg);
      background: rgba(var(--fg-rgb), 0.06);
    }
    .pal-chips {
      display: inline-flex;
      gap: 0;
    }
    .pal-chips span {
      display: block;
      width: 16px;
      height: 18px;
      border-right: 1px solid rgba(0, 0, 0, 0.08);
    }
    .pal-chips span:last-child { border-right: none; }
    .pal-label {
      font-family: 'Crimson Pro', serif;
      font-size: 0.98rem;
      color: var(--fg);
      font-weight: 500;
      line-height: 1;
    }
    @media (max-width: 640px) {
      .palette-selector { gap: 0.4rem; padding: 0.65rem clamp(1.25rem, 4vw, 2.5rem); }
      .palette-selector .sel-k { width: 100%; margin-bottom: 0.25rem; }
      .pal-label { font-size: 0.9rem; }
    }

    .topbar {
      display: flex;
      justify-content: space-between;
      gap: 1rem;
      padding: 1rem 0;
      font-family: 'JetBrains Mono', ui-monospace, monospace;
      font-size: 0.7rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: rgba(var(--fg-rgb), 0.6);
      border-bottom: 1px solid rgba(var(--fg-rgb), 0.2);
      border-top: 1px solid rgba(var(--fg-rgb), 0.2);
    }

    .section-head {
      margin: 5rem 0 2rem;
      border-top: 1px solid rgba(var(--fg-rgb), 0.25);
      padding-top: 1.25rem;
    }
    .section-head h2 {
      font-size: clamp(1.8rem, 3vw, 2.6rem);
      margin: 0;
